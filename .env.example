# amp environment variables
# Copy to .env and fill in your values (never commit .env to git!)

# OpenAI API key (required for default OpenAI provider)
OPENAI_API_KEY=sk-...

# Anthropic API key (optional, if using anthropic provider)
# ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot token (optional, for telegram bot interface)
# TELEGRAM_BOT_TOKEN=...

# Override default mode (optional)
# AMP_DEFAULT_MODE=auto

# Override model (optional)
# AMP_MODEL=gpt-4o-mini
